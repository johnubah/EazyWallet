@model WalletReport.Models.WalletLoadRequest

@{
    ViewBag.Title = "Loading Agent Wallet";
    String ReadOnly = "false";
    String IDReference = ViewBag.IDReference;
  
}

@using (Html.BeginForm(null, null, FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <div id="content">
        <!-- Content start -->
        <div class="top_bar">
            <ul class="breadcrumb">
                <li><a href="dashboard.html"><i class="icon-home"></i></a> <span class="divider">/</span></li>
                <li class="active"><a href="#">Wallet Load</a></li>
            </ul>
        </div>

        @Html.Hidden("IDReference", IDReference)
        <div class="inner_content" ng-app="">

            <div class="widgets_area">

                <div class="row-fluid">
                    <div class="span12">
                        <div class="well black">
                            <div class="well-header">
                                <h5>Load Wallet Request</h5>
                            </div>
                            <div class="well-content no_padding no-search">

                                <div id="rootwizard4">
                                    <div class="wizard_navigation">
                                        <ul>
                                            <li>
                                                <a href="#tab11" data-toggle="tab">
                                                    <span>
                                                        <i class="icon-user"></i>
                                                        <strong>1</strong>
                                                    </span> Wallet Load information
                                                </a>
                                            </li>
                                            <li>
                                                <a href="#tab13" data-toggle="tab">
                                                    <span>
                                                        <i class="icon-grid"></i>
                                                        <strong>2</strong>
                                                    </span> Finalize
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                    <div class="wizard_bar">
                                        <div class="progress progress-danger progress-striped">
                                            <div class="bar"></div>
                                        </div>
                                    </div>
                                    <div class="tab-content">
                                        <div class="tab-pane no_padding" id="tab11">
                                            <div class="form_row">
                                                <label class="field_name align_right">Dealer Information</label>
                                                <div class="field">
                                                    @Html.DropDownListFor(c => c.DealerId, (SelectList)ViewBag.Dealers, new Dictionary<String, Object>() { { "class", "span6 required" } })
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Agent Information</label>
                                                <div class="field">
                                                    <select id="AgentID" name="AgentID" class="span6 required">

                                                    </select>
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Description</label>
                                                <div class="field">
                                                    @Html.TextBoxFor(c => c.Description, new Dictionary<String, Object>() { { "class", "span6 required" } })
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Reference Number</label>
                                                <div class="field">
                                                    @Html.TextBoxFor(c => c.ReferenceNumber, new Dictionary<String, Object>() { { "class", "span6 required" } })
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Amount </label>
                                                <div class="field">
                                                    @Html.TextBoxFor(c => c.Amount, new Dictionary<String, Object>() { { "class", "span6 required" } })
                                                </div>
                                            </div>

                                        </div>

                                        <div class="tab-pane no_padding" id="tab13">
                                            <div class="form_row">
                                                <label class="field_name align_right">Agent Name</label>
                                                <div class="field">
                                                    <span id="spAgentName" class="help-inline"></span>
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Description</label>
                                                <div class="field">
                                                    <span id="spDescription" class="help-inline"></span>
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Reference</label>
                                                <div class="field">
                                                    <span id="spReferenceNumber" class="help-inline"></span>
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Amount</label>
                                                <div class="field">
                                                    <span id="spAmount" class="help-inline"></span>
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Agent Information</label>
                                                <div class="field">
                                                    <select id="ConfirmAgentID" name="ConfirmAgentID" class="span6 required"></select>
                                                </div>
                                            </div>
                                            
                                            <div class="form_row">
                                                <label class="field_name align_right">Please Enter Confirmation Code</label>
                                                <div class="field">
                                                    @Html.TextBoxFor(c => c.ConfirmationCode, new Dictionary<String, Object>() { { "class", "span6 required" } })
                                                </div>
                                            </div>
                                            
                                        </div>
                                        <div class="form_row wizard_buttons">
                                            <div class="field">
                                                <a href="@Url.Content("~/Wallet/Index")" class="btn">Cancel</a>
                                                <span class="btn red previous-button">Previous</span>
                                                <span id="nextClick" class="btn light_blue next-button">Next</span>
                                                @if (ReadOnly == "false")
                                                {
                                                    <input type="submit" class="btn dark_green submit-button" value="Post" onclick="return validateDealer();" />
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section scripts
{
    <script type="text/javascript">
        jQuery(document).ready(function () {
            var isSendSMS = false;
            jQuery("#nextClick").click(function () {

                jQuery("#spAgentName").text(jQuery("#AgentID option:selected").text());
                jQuery("#spDescription").text(jQuery("#Description").val());
                jQuery("#spReferenceNumber").text(jQuery("#ReferenceNumber").val());
                jQuery("#spAmount").text(jQuery("#Amount").val());

                //we need to send confirmation code using jquery

                jQuery.post("../Wallet/NotifyCustomer", { reference: 1 }, function (result) {
                    $("span").html(result);
                });


            });


        });
        function validateDealer()
        {
            //DealerId
            var agentToPost = jQuery("#AgentID").val();
            var agentToValidate = jQuery("#ConfirmAgentID").val();
            if (agentToPost == "0")
            {
                alert("Please select an Agent");
                return false;
            }

            if (agentToPost != agentToValidate)
            {
                alert("Agent selected is different from confirmation Agent");
                return false;
            }

            return true;
        }
    </script>
    @Scripts.Render("~/Scripts/library/jquery.bootstrap.wizard.js")
    @Scripts.Render("~/Scripts/library/jquery.validate.js")
    @Scripts.Render("~/Scripts/flatpoint_core.js")
    @Scripts.Render("~/Scripts/forms_layout.js")
    @Scripts.Render("~/Scripts/forms_wizard.js")
    <script type="text/javascript">
        jQuery("#DealerId").change(function () {
            var dID = jQuery(this).val();
            LoadAgent(dID);

        });

        function LoadAgent(dID) {
            jQuery.getJSON("../Agent/LoadAgentByDealer", { Id: dID },
                    function (data) {
                        var AgentSelect = jQuery("#AgentID");
                        var confirmAgentSelect = jQuery("#ConfirmAgentID");
                        AgentSelect.empty();
                        confirmAgentSelect.empty();
                        AgentSelect.append(jQuery('<option>', {
                            value: 0,
                            text: "select an Agent"
                        }));
                        confirmAgentSelect.append(jQuery('<option>', {
                            value: 0,
                            text: "select an Agent"
                        }));
                        jQuery.each(data, function (index, itemData) {
                            AgentSelect.append(jQuery('<option>', {
                                value: itemData.Id,
                                text: itemData.AgenName
                            }));
                        });
                        jQuery.each(data, function (index, itemData) {
                            confirmAgentSelect.append(jQuery('<option>', {
                                value: itemData.Id,
                                text: itemData.AgenName
                            }));
                        });

                    });
        }
    </script>
}