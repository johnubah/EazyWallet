        <link rel="apple-touch-icon-precomposed" href="@Url.Content("~/Images/apple-touch-icon-57-precomposed.png")" />
        <link rel="shortcut icon" href="@Url.Content("~/Images/favicon.png")" />
        @Scripts.Render("~/Scripts/jquery-1.10.2.js")
        @Scripts.Render("~/Scripts/jquery-ui-1.10.3.js")
        @Scripts.Render("~/Scripts/bootstrap.js")

        @Scripts.Render("~/Scripts/library/jquery.collapsible.min.js")
        @Scripts.Render("~/Scripts/library/jquery.mCustomScrollbar.min.js")
        @Scripts.Render("~/Scripts/library/jquery.mousewheel.min.js")
        @Scripts.Render("~/Scripts/library/jquery.uniform.min.js")

        @Scripts.Render("~/Scripts/library/jquery.sparkline.min.js")
        @Scripts.Render("~/Scripts/library/chosen.jquery.min.js")
        @Scripts.Render("~/Scripts/library/jquery.easytabs.js")
        @Scripts.Render("~/Scripts/library/flot/excanvas.min.js")
        @Scripts.Render("~/Scripts/library/flot/jquery.flot.js")
        @Scripts.Render("~/Scripts/library/flot/jquery.flot.pie.js")
        @Scripts.Render("~/Scripts/library/flot/jquery.flot.selection.js")
        @Scripts.Render("~/Scripts/library/flot/jquery.flot.resize.js")
        @Scripts.Render("~/Scripts/library/flot/jquery.flot.orderBars.js")
        @Scripts.Render("~/Scripts/library/maps/jquery.vmap.js")
        @Scripts.Render("~/Scripts/library/maps/maps/jquery.vmap.world.js")
