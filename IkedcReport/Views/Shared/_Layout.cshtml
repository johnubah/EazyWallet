<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <title>WALLET REPORT</title>
        <link href="~/favicon.ico" rel="shortcut icon" type="image/x-icon" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="author" content="">

        <link href="@Url.Content("~/Content/bootstrap.css")" rel="stylesheet" />
        <link href="@Url.Content("~/Content/bootstrap-responsive.css")" rel="stylesheet" />
        <link href="@Url.Content("~/Content/stylesheet.css")" rel="stylesheet" />
        <link href="@Url.Content("~/Content/icon/font-awesome.css")" rel="stylesheet" />
        <link href='http://fonts.googleapis.com/css?family=Open+Sans:400,300,600,700,800' rel='stylesheet' type='text/css' />

        <!-- Le fav and touch icons -->
        <link rel="apple-touch-icon-precomposed" sizes="144x144" href="@Url.Content("~/Images/apple-touch-icon-144-precomposed.png")" />
        <link rel="apple-touch-icon-precomposed" sizes="114x114" href="@Url.Content("~/Images/apple-touch-icon-114-precomposed.png")" />
