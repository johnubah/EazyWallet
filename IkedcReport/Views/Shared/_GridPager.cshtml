@model GridMvc.Pagination.GridPager
@if (Model == null || Model.PageCount <= 1)
{
    return;
}

<div class="pagination">
    <ul >
        @if (Model.CurrentPage > 1)
        {
            <li class="prev">
                <a href="#" data-PageIndex="@Model.GetLinkForPage(Model.CurrentPage - 1)">Previous</a>
            </li>
        }

        @if (Model.StartDisplayedPage > 1)
        {
            <li class="active">
                <a  href="#" data-PageIndex="@Model.GetLinkForPage(1)">1</a>
            </li>
            if (Model.StartDisplayedPage > 2)
            {
            <li class="next"><a   href="#" data-PageIndex="@Model.GetLinkForPage(Model.StartDisplayedPage - 1)" >...</a></li>
            }
        }
        @for (int i = Model.StartDisplayedPage; i <= Model.EndDisplayedPage; i++)
        {
            if (i == Model.CurrentPage)
            {
            <li><span>@i</span></li>
            }
            else
            {
            <li class="next"><a  href="#" data-PageIndex="@Model.GetLinkForPage(i)">@i</a></li>
            }
        }
        @if (Model.EndDisplayedPage < Model.PageCount)
        {
            if (Model.EndDisplayedPage < Model.PageCount - 1)
            {
            <li class="next"><a  href="#" data-PageIndex="@Model.GetLinkForPage(Model.EndDisplayedPage + 1)">...</a></li>
            }
            <li><a href="#" data-PageIndex="@Model.GetLinkForPage(Model.PageCount)">@Model.PageCount</a></li>
        }
        @if (Model.CurrentPage < Model.PageCount)
        {
            <li class="next"><a href="#" data-PageIndex="@Model.GetLinkForPage(Model.CurrentPage + 1)">Next</a></li>
        }
    </ul>
</div>
