                        </div>
                    </div>
                </div>



            </div>
            <div class="widgets_area">
                <div class="row-fluid">
                    <div class="span12">
                        <div class="well grey">
                            <div class="well-header">
                                <h5>Users List</h5>
                              @*  <ul>
                                    <li class="color_pick"><a href="#"><i class="icon-th"></i></a>
                                        <ul>
                                            <li><a class="blue set_color" href="#"></a></li>
                                            <li><a class="light_blue set_color" href="#"></a></li>
                                            <li><a class="grey set_color" href="#"></a></li>
                                            <li><a class="pink set_color" href="#"></a></li>
                                            <li><a class="red set_color" href="#"></a></li>
                                            <li><a class="orange set_color" href="#"></a></li>
                                            <li><a class="yellow set_color" href="#"></a></li>
                                            <li><a class="green set_color" href="#"></a></li>
                                            <li><a class="dark_green set_color" href="#"></a></li>
                                            <li><a class="turq set_color" href="#"></a></li>
                                            <li><a class="dark_turq set_color" href="#"></a></li>
                                            <li><a class="purple set_color" href="#"></a></li>
                                            <li><a class="violet set_color" href="#"></a></li>
                                            <li><a class="dark_blue set_color" href="#"></a></li>
                                            <li><a class="dark_red set_color" href="#"></a></li>
                                            <li><a class="brown set_color" href="#"></a></li>
                                            <li><a class="black set_color" href="#"></a></li>
                                        </ul>
                                    </li>
                                </ul>*@
                            </div>

                            <div class="well-content">
                                @Html.HiddenFor(m=>m.CurrentPageIndex)
                                @if ((bool)ViewBag.IsPagination)
                                {
                                     
                                     <div class="row-fluid">
                                      <div class="pull-left span6">
                                          @Html.DropDownListFor(m => m.PageSize, (SelectList)ViewBag.PageSizeSELECT)
                                     </div>
                                   </div>
                                 }
                                <table class="table table-striped table-bordered table-hover datatable">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Username</th>
                                            <th>First name</th>
                                            <th>Last Name</th>
                                            <th>Display name</th>
                                            <th>Email</th>
                                            <th>Mobile</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (ViewBag.Users != null && ((List<WalletReport.Models.User>)ViewBag.Users).Count() > 0)
                                        {
                                            int i = 0;
                                            foreach (WalletReport.Models.User oUser in (List<WalletReport.Models.User>)ViewBag.Users)
                                            {
                                                <tr>
                                                    <td>@(++i)</td>
                                                     <td>@oUser.Username</td>
                                                    <td>@oUser.Firstname</td>
                                                    <td>@oUser.LastName</td>
                                                    <td>@oUser.DisplayName</td>
                                                    <td>@oUser.EmailAddress</td>
                                                    <td>@oUser.Mobile</td>
                                                    <td><a href="@Url.Content(String.Format("~/User/Create?Id={0}",oUser.Id))">
                                                        <span class="label label-success">Edit</span></a>
                                                        @if(oUser.IsActive)
                                                        {
                                                            <a href="@Url.Content(String.Format("~/User/Deactive?Id={0}",oUser.Id))">
                                                            <span class="label label-warning">Deactivate</span></a>
                                                        }
                                                        else
                                                        {
                                                             <a href="@Url.Content(String.Format("~/User/Activete?Id={0}",oUser.Id))">
                                                            <span class="label label-warning">Activate User</span></a>
                                                        }

                                                             <a href="@Url.Content(String.Format("~/User/ResetUser?Id={0}",oUser.Id))">
                                                        <span class="label label-important">Reset User</span></a>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                    <td>&nbsp;</td>
                                                     <td>&nbsp;</td>
                                                    <td>&nbsp;</td>
                                                    <td>&nbsp;</td>
                                                    <td>&nbsp;</td>
                                                    <td>&nbsp;</td>
                                                    <td>&nbsp;</td>
                                                    <td>
                                                        &nbsp;
                                                    </td>
                                                </tr>
                                        }
                                    </tbody>
                                </table>
                                @if ((bool)ViewBag.IsPagination)
                                {
                                     <div id="DataPager" class="row-fluid">
                                          <div id="DataPagerRight" class="pull-right">
                                              <div class="pagination">
                                                  @Html.Pager(Model.PageSize, Model.CurrentPageIndex, Model.ItemCount)
                                              </div>
                                              
                                         </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
 }
@section scripts
{
    
@Scripts.Render("~/Scripts/library/footable/footable.js")
@Scripts.Render("~/Scripts/library/footable/data-generator.js")
@Scripts.Render("~/Scripts/library/bootstrapSwitch.js")
@Scripts.Render("~/Scripts/library/bootstrap-modal.js")
@Scripts.Render("~/Scripts/library/bootstrap-modalmanager.js")
@Scripts.Render("~/Scripts/library/editor/wysihtml5-0.3.0.js")
@Scripts.Render("~/Scripts/library/editor/bootstrap-wysihtml5.js")
@Scripts.Render("~/Scripts/forms_advanced.js")


    <script type="text/javascript">



        jQuery(document).ready(function () {

            jQuery('#DataPagerRight a').click(function () {

                var pageIndex = jQuery(this).attr("data-PageIndex");

                jQuery("#CurrentPageIndex").val(pageIndex);

                var form = jQuery("form#form1");
                form.attr("action", "@Url.Action("UserList","User")");
                form.submit();

                return true;

            });

            jQuery("#PageSize").change(function () {
                var form = jQuery("form#form1");
                form.attr("action", "@Url.Action("UserList","User")");
                try {
                    jQuery("#CurrentPageIndex").val("0");
                }
                catch (e) {
                }
                form.submit();

                return true;
            });
        });
        function Search() {
            jQuery("#CurrentPageIndex").val("0");
            var form = jQuery("form#form1");
            form.attr("action", "@Url.Action("UserList","User")");
            form.submit();
            return true;
        }
   
    </script>
	
	
}