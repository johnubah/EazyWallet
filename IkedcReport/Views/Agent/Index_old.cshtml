
@model WalletReport.Models.GeneralSearch
@{
    ViewBag.Title = "UserList";
}

@using(Html.BeginForm(null,null, FormMethod.Post, new Dictionary<String, Object>() { { "Id", "form1" }, { "name", "form1" } }))
{
 <div id="content"> <!-- Content start -->
        <div class="top_bar">
            <ul class="breadcrumb">
              <li><a href="dashboard.html"><i class="icon-home"></i></a> <span class="divider">/</span></li>
              <li class="active"><a href="@Url.Content("~/Home/Index")">Dashboard</a></li>
            </ul>
        </div>

        <div class="inner_content">
          @*  <div class="statistic clearfix">
                <div class="current_page float_left">
                    <span><i class="icon-reorder"></i> Datatables</span>
                </div>

                <div class="charts clearfix">
                    <div class="statistic_chart pull-right">
                        <div id="sparkline" class="pull-left sparkline"></div> 
                        <div class="bars_label first_label pull-left">
                            <span class="value">CPU</span>
                        </div>

                        <div id="sparkline2" class="pull-left sparkline"></div> 
                        <div class="bars_label pull-left">
                            <span class="value">RAM</span>
                        </div>
                    </div>
                </div>
            </div>*@

            <div class="user_bar">
                <div class="row-fluid">
                    <div class="span6 no-search">
                        <a href="@Url.Content("~/Agent/Create")" class="btn dark_green submit-button">Create</a>
                    </div>

                   @* <div class="span6">
                        <div class="search">
                            <input type="text" data-provide="typeahead" name="search" class="typehead span8" placeholder="Search for something" data-source='["Alabama","Alaska","Arizona","Arkansas","California","Colorado","Connecticut","Delaware","Florida","Georgia","Hawaii","Idaho","Illinois","Indiana","Iowa","Kansas","Kentucky","Louisiana","Maine","Maryland","Massachusetts","Michigan","Minnesota","Mississippi","Missouri","Montana","Nebraska","Nevada","New Hampshire","New Jersey","New Mexico","New York","North Dakota","North Carolina","Ohio","Oklahoma","Oregon","Pennsylvania","Rhode Island","South Carolina","South Dakota","Tennessee","Texas","Utah","Vermont","Virginia","Washington","West Virginia","Wisconsin","Wyoming"]'>
                            <button type="submit" class="square-button color-green"><i class="icon-plus"></i></button>
                        </div>
                    </div>*@
                </div>
                 <div class="row-fluid">
                    <div class="span12">
                        <div class="well grey">
                            <div class="well-header">
                                <h5>Search</h5>
                            </div>

                            <div class="well-content no-search">
                                <div class="form_row">
                                    <label class="field_name">Search Criteria</label>
                                    <div class="field">
                                         @Html.DropDownListFor(model => model.SearchCriteria, (SelectList)ViewBag.SearchList)
                                    </div>
                                </div>
                                <div class="form_row">
                                    <label class="field_name">Search Text</label>
                                    <div class="field">
                                        @Html.TextBoxFor(m => m.SearchValue)
                                    </div>
                                </div>
                                <div class="form_row">
                                    <label class="field_name"></label>
                                    <div class="field">
                                         <input type="button" class="btn dark_green submit-button" value="Search" onclick="return Search()" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="widgets_area">
                <div class="row-fluid">
                    <div class="span12">
                        <div class="well grey">
                            <div class="well-header">
                                <h5>Agent List</h5>
                                @Html.HiddenFor(c => c.CurrentPageIndex)
                            </div>

                            <div class="well-content">
                                 @if ((bool)ViewBag.IsPagination)
                                 {
                                     
                                     <div class="row-fluid">
                                      <div class="pull-left span6">
                                          @Html.DropDownListFor(m => m.PageSize, (SelectList)ViewBag.PageSizeSELECT)
                                     </div>
                                   </div>
                                 }
                                <table class="table table-striped table-bordered table-hover datatable">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Name</th>
                                            <th>Address</th>
                                            <th>Email</th>
                                            <th>Date</th>
                                            <th>Balance</th>
                                            <th>Agent Acct</th>
                                            <th>UBA Agent Acct</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (ViewBag.Agents != null && ((List<WalletReport.Models.AgentUser>)ViewBag.Agents).Count() > 0)
                                        {
                                            int count = 0;
                                            foreach (WalletReport.Models.AgentUser d in (List<WalletReport.Models.AgentUser>)ViewBag.Agents)
                                            {
                                                <tr>
                                                    <td>@(++count)</td>
                                                    <td>@d.AgenName</td>
                                                    <td>@d.AddressLine1</td>
                                                    <td>@d.ContactEmail</td>
                                                    <td>@d.ContactMobile</td>
                                                    <td>@d.Balance.ToString("N2")</td>
                                                    <td>@d.AccountNo</td>
                                                    <td>@d.UBAAccountNo</td>
                                                    <td>
                                                        <a href="@Url.Content(String.Format("~/Agent/Create?Id={0}", d.Id))">
                                                            <span class="label label-success">Edit</span>
                                                        </a>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    
        
                                   
                                    </tbody>
                                </table>
                                @if ((bool)ViewBag.IsPagination)
                                {
                                     <div id="DataPager" class="row-fluid">
                                          <div id="DataPagerRight" class="pull-right">
                                              <div class="pagination">
                                                  @Html.Pager(Model.PageSize, Model.CurrentPageIndex, Model.ItemCount)
                                              </div>
                                              
                                         </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
}
@section scripts
{
    
@Scripts.Render("~/Scripts/library/footable/footable.js")
@Scripts.Render("~/Scripts/library/footable/data-generator.js")
@Scripts.Render("~/Scripts/library/bootstrapSwitch.js")
@Scripts.Render("~/Scripts/library/bootstrap-modal.js")
@Scripts.Render("~/Scripts/library/bootstrap-modalmanager.js")
@Scripts.Render("~/Scripts/library/editor/wysihtml5-0.3.0.js")
@Scripts.Render("~/Scripts/library/editor/bootstrap-wysihtml5.js")
@Scripts.Render("~/Scripts/forms_advanced.js")


    <script type="text/javascript">



        jQuery(document).ready(function () {

            jQuery('#DataPagerRight a').click(function () {

                var pageIndex = jQuery(this).attr("data-PageIndex");

                jQuery("#CurrentPageIndex").val(pageIndex);

                var form = jQuery("form#form1");
                form.attr("action", "@Url.Action("Index","Agent")");
                form.submit();

                return true;

            });

            jQuery("#PageSize").change(function () {
                var form = jQuery("form#form1");
                form.attr("action", "@Url.Action("Index","Agent")");
                try {
                    jQuery("#CurrentPageIndex").val("0");
                }
                catch (e) {
                }
                form.submit();

                return true;
            });
        });
        function Search() {
            jQuery("#CurrentPageIndex").val("0");
            var form = jQuery("form#form1");
            form.attr("action", "@Url.Action("Index","Agent")");
            form.submit();
            return true;
        }
    </script>
	
	
}