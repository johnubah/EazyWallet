@model WalletReport.Models.AgentUser

@{
    ViewBag.Title = "Dealer Creation";
}

@using(Html.BeginForm(null,null, FormMethod.Post))
{
  @Html.AntiForgeryToken()
  <div id="content"> <!-- Content start -->
        <div class="top_bar">
            <ul class="breadcrumb">
              <li><a href="dashboard.html"><i class="icon-home"></i></a> <span class="divider">/</span></li>
              <li class="active"><a href="#">Agent Creation</a></li>
            </ul>
        </div>

        <div class="inner_content" ng-app="">
             
            <div class="widgets_area">
                @Html.HiddenFor(m => m.Id)
					 <div class="row-fluid">
                            <div class="span12">
                                <div class="well black">
                                    <div class="well-header">
                                        <h5>Agent Creation</h5>
                                    </div>
                                    <div class="well-content no_padding no-search">
                                        
                                            <div id="rootwizard4">
                                                <div class="wizard_navigation">
                                                    <ul>
                                                        <li><a href="#tab11" data-toggle="tab">
                                                            <span>
                                                                <i class="icon-user"></i>
                                                                <strong>1</strong>
                                                            </span> Agent information</a></li>
                                                        <li>
                                                            <a href="#tab12" data-toggle="tab">
                                                            <span>
                                                                <i class="icon-reorder"></i>
                                                                <strong>3</strong>
                                                            </span> Contact Information</a></li>
                                                        <li><a href="#tab13" data-toggle="tab">
                                                            <span>
                                                                <i class="icon-grid"></i>
                                                                <strong>4</strong>
                                                            </span> Finalize</a></li>
                                                    </ul>
                                                </div>
                                                <div class="wizard_bar">
                                                    <div class="progress progress-danger progress-striped">
                                                      <div class="bar"></div>
                                                    </div>
                                                </div>
                                                <div class="tab-content">
                                                    <div class="tab-pane no_padding" id="tab11">
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Dealer Information</label>
                                                            <div class="field">
                                                                @Html.DropDownListFor(c => c.DealerId,(SelectList)ViewBag.Dealers, new Dictionary<String, Object>() {{"class","span6 required"} })
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Posting Mode</label>
                                                            <div class="field">
                                                                @Html.DropDownListFor(c => c.PostingMode, (SelectList)ViewBag.PostingModeSelectView, new Dictionary<String, Object>() { { "class", "span6 required" } })
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Agent Name</label>
                                                            <div class="field">
                                                                @Html.TextBoxFor(c => c.AgenName, new Dictionary<String, Object>() {{"class","span6 required"} })
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Address 1</label>
                                                            <div class="field">
                                                                 @Html.TextBoxFor(c => c.AddressLine1, new Dictionary<String, Object>() {{"class","span6 required"} })
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Address 2</label>
                                                            <div class="field">
                                                               @Html.TextBoxFor(c => c.AddressLine2, new Dictionary<String, Object>() {{"class","span6 required"} })
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">City</label>
                                                            <div class="field">
                                                                @Html.TextBoxFor(c => c.City, new Dictionary<String, Object>() {{"class","span6 required"} })
                                                               @* <input class="span6" id="city" name="city" type="text">*@
                                                            </div>
                                                        </div>
                                                         <div class="form_row">
                                                            <label class="field_name align_right">State</label>
                                                            <div class="field">
                                                                @Html.TextBoxFor(c => c.State, new Dictionary<String, Object>() {{"class","span6 required"} })
                                                               @* <input class="span6" id="city" name="city" type="text">*@
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Country</label>
                                                            <div class="field">
                                                                @Html.TextBoxFor(c => c.Country, new Dictionary<String, Object>() {{"class","span6 required"} })
                                                               @* <input class="span6" id="city" name="city" type="text">*@
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="tab-pane no_padding" id="tab12">
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Contact Name</label>
                                                            <div class="field">
                                                                 @Html.TextBoxFor(c => c.ContactName,  new Dictionary<String, Object>() {{"class","span6 required"} })
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Contact Address</label>
                                                            <div class="field">
                                                                 @Html.TextBoxFor(c => c.ContactAddress, new Dictionary<String, Object>() {{"class","span6 required"} })
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Contact Email</label>
                                                            <div class="field">
                                                                 @Html.TextBoxFor(c => c.ContactEmail, new Dictionary<String, Object>() {{"class","span6 required"} })
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Contact Mobile</label>
                                                            <div class="field">
                                                                @Html.TextBoxFor(c => c.ContactMobile, new Dictionary<String, Object>() {{"class","span6 required"} })
                                                            </div>
                                                        </div>
                                                        
                                                    </div>
                                                    <div class="tab-pane no_padding" id="tab13">
                                                        <div class="form_row">
                                                            <label class="field_name align_right">DealerName</label>
                                                            <div class="field">
                                                                <span  id="spDealerName" class="help-inline"></span>
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Agent Name</label>
                                                            <div class="field">
                                                                <span id="spAgentName" class="help-inline"></span>
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">AddressLine1</label>
                                                            <div class="field">
                                                                <span id="spAddressLine1" class="help-inline"></span>
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">AddressLine2</label>
                                                            <div class="field">
                                                                <span id="spAddressLine2" class="help-inline"></span>
                                                            </div>
                                                        </div>
                                                         <div class="form_row">
                                                            <label class="field_name align_right">City</label>
                                                            <div class="field">
                                                                <span id="spCity" class="help-inline"></span>
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">State</label>
                                                            <div class="field">
                                                                <span id="spState" class="help-inline"></span>
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Contact Name</label>
                                                            <div class="field">
                                                                <span id="spContactName" class="help-inline"></span>
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Contact Address</label>
                                                            <div class="field">
                                                                <span id="spContactAddress" class="help-inline"></span>
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Contact Email</label>
                                                            <div class="field">
                                                                <span id="spContactEmail" class="help-inline"></span>
                                                            </div>
                                                        </div>
                                                        <div class="form_row">
                                                            <label class="field_name align_right">Contact Mobile</label>
                                                            <div class="field">
                                                                <span id="spContactMobile" class="help-inline"></span>
                                                            </div>
                                                        </div>
                                                    </div>
                                                   

                                                    <div class="form_row wizard_buttons">
                                                        <div class="field">
                                                             <a href="@Url.Content("~/Agent/Index")" class="btn">Cancel</a>
                                                            <span class="btn red previous-button">Previous</span>
                                                            <span id="nextClick" class="btn light_blue next-button">Next</span>
                                                            <input type="submit" class="btn dark_green submit-button" value="Save" />
                                                           @* <span class="btn dark_green submit-button">Submit</span>*@
                                                        </div>
                                                    </div>
                                                </div>  
                                            </div>
                                        </div>
                                    </div>
                                </div>
                     </div>
             </div>
         </div>
    </div>
}
       
@section scripts
{
      <script type="text/javascript">
        jQuery(document).ready(function () {

            jQuery("#nextClick").click(function () {

                jQuery("#spContactMobile").text(jQuery("#ContactMobile").val());
                jQuery("#spContactEmail").text(jQuery("#ContactEmail").val());
                jQuery("#spContactAddress").text(jQuery("#ContactAddress").val());
                jQuery("#spContactName").text(jQuery("#ContactName").val());
                jQuery("#spState").text(jQuery("#State").val());

                jQuery("#spCity").text(jQuery("#City").val());
                jQuery("#spAddressLine2").text(jQuery("#AddressLine2").val());

                jQuery("#spAddressLine1").text(jQuery("#AddressLine1").val());
                jQuery("#spAgentName").text(jQuery("#AgenName").val());
                //
                var dealer = jQuery("#DealerId option:selected").text();

                jQuery("#spDealerName").text(dealer);

            });

        });
    </script>
   @Scripts.Render("~/Scripts/library/jquery.bootstrap.wizard.js")
@Scripts.Render("~/Scripts/library/jquery.validate.js")
@Scripts.Render("~/Scripts/flatpoint_core.js")
@Scripts.Render("~/Scripts/forms_layout.js")
@Scripts.Render("~/Scripts/forms_wizard.js")
}