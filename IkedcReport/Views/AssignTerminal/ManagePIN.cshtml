@model WalletReport.Models.TerminalAssignment

@{
    String title = (bool)ViewBag.HasTerminalPIN ? "PIN RESET FOR TERMINAL" : "PIN RESET FOR TERMINAL";
    String saveText = (bool)ViewBag.HasTerminalPIN ? "Reset PIN" : "Create PIN";
}

@using (Html.BeginForm(null, null, FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <div id="content">
        <!-- Content start -->
        <div class="top_bar">
            <ul class="breadcrumb">
                <li><a href="dashboard.html"><i class="icon-home"></i></a> <span class="divider">/</span></li>
                <li class="active"><a href="#">@title</a></li>
            </ul>
        </div>
       
        <div class="inner_content">

            <div class="widgets_area">

                <div class="row-fluid">
                    <div class="span12">
                        <div class="well black">
                            <div class="well-header">
                                <h5>Terminal Cash Assignment</h5>
                            </div>
                            <div class="well-content no_padding no-search">

                                <div class="row" style="margin-bottom:20px">
                                    
                                   
                              
                                            <div class="form_row">
                                                <label class="field_name align_right">Terminal ID</label>
                                                <div class="field">
                                                    @Html.TextBoxFor(c => c.TerminalID, new Dictionary<String, Object>() { { "class", "span6 required" }, {"readonly","readonly" } })
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Dealer Name</label>
                                                <div class="field">
                                                   <input type="text" value="@ViewBag.Dealer" class="span6" readonly="readonly" />
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Agent Name</label>
                                                <div class="field">
                                                    <input type="text" value="@ViewBag.Agent" class="span6" readonly="readonly" />
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Debit Limit</label>
                                                <div class="field">
                                                    @Html.TextBoxFor(c => c.DebitLimit, new Dictionary<String, Object>() { { "class", "span6 required" } })
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">PIN</label>
                                                <div class="field">
                                                   <input type="password" id="Pin" name="Pin" class="span6 required" />
                                                </div>
                                            </div>
                                            <div class="form_row">
                                                <label class="field_name align_right">Confirm PIN</label>
                                                <div class="field">
                                                    <input type="password" id="ConfirmPin" name="ConfirmPin" class="span6 required" />
                                                </div>
                                            </div>

                                    
                                        <div class="form_row">
                                            <div class="field">
                                                <a href="@Url.Content("~/Agent/Index")" class="btn">Cancel</a>
                                                <input type="submit" class="btn dark_green submit-button" value="@saveText" />
                                            </div>
                                        </div>
                              
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}


    @Scripts.Render("~/Scripts/library/jquery.bootstrap.wizard.js")
    @Scripts.Render("~/Scripts/library/jquery.validate.js")
    @Scripts.Render("~/Scripts/flatpoint_core.js")
    @Scripts.Render("~/Scripts/forms_layout.js")
}