
@model WalletReport.Models.GeneralSearch
@{
    ViewBag.Title = "UserList";
}

@using(Html.BeginForm(null,null, FormMethod.Post, new Dictionary<String, Object>() { { "Id", "form1" }, { "name", "form1" } }))
{
 <div id="content"> <!-- Content start -->
        <div class="top_bar">
            <ul class="breadcrumb">
              <li><a href="dashboard.html"><i class="icon-home"></i></a> <span class="divider">/</span></li>
              <li class="active"><a href="@Url.Content("~/Home/Index")">Dashboard</a></li>
            </ul>
        </div>

        <div class="inner_content">

            <div class="user_bar">
                <div class="row-fluid">
                    <div class="span6 no-search">
                        <a href="@Url.Content("~/AssignTerminal/Create")" class="btn dark_green submit-button">Create</a>
                    </div>

                </div>
                 <div class="row-fluid">
                    <div class="span12">
                        <div class="well grey">
                            <div class="well-header">
                                <h5>Search</h5>
                            </div>

                            <div class="well-content no-search">
                                <div class="form_row">
                                    <label class="field_name">Search Criteria</label>
                                    <div class="field">
                                         @Html.DropDownListFor(model => model.SearchCriteria, (SelectList)ViewBag.SearchList)
                                    </div>
                                </div>
                                <div class="form_row">
                                    <label class="field_name">Search Text</label>
                                    <div class="field">
                                        @Html.TextBoxFor(m => m.SearchValue)
                                    </div>
                                </div>
                                <div class="form_row">
                                    <label class="field_name"></label>
                                    <div class="field">
                                         <input type="button" class="btn dark_green submit-button" value="Search" onclick="return Search()" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="widgets_area">
                <div class="row-fluid">
                    <div class="span12">
                        <div class="well grey">
                            <div class="well-header">
                                <h5>Terminal Assignment List</h5>
                                @Html.HiddenFor(c => c.CurrentPageIndex)
                            </div>

                            <div class="well-content">
                                 @if ((bool)ViewBag.IsPagination)
                                 {
                                     
                                     <div class="row-fluid">
                                      <div class="pull-left span6">
                                          @Html.DropDownListFor(m => m.PageSize, (SelectList)ViewBag.PageSizeSELECT)
                                     </div>
                                   </div>
                                 }
                                <table class="table table-striped table-bordered table-hover datatable">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Terminal ID</th>
                                            <th>Dealer Name</th>
                                            <th>Agent Name</th>
                                            <th>Debit Limit</th>
                                            <th>Ignore Limit</th>
                                            <th>Status</th>
                                            <th>Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (ViewBag.Terminals != null && ((List<WalletReport.Models.TerminalAssignmentVM>)ViewBag.Terminals).Count() > 0)
                                        {
                                            int count = 0;
                                            foreach (WalletReport.Models.TerminalAssignmentVM d in (List<WalletReport.Models.TerminalAssignmentVM>)ViewBag.Terminals)
                                            {
                                                <tr>
                                                    <td>@(++count)</td>
                                                    <td>@d.TerminalID</td>
                                                    <td>@d.DealerName</td>
                                                    <td>@d.AgentName</td>
                                                    <td>@d.DebitLimit</td>
                                                    <td>@d.IgnoreLimit</td>
                                                    <td>
                                                    @if(d.IsActive)
                                                    {
                                                        <span class="label label-success">Active</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="label label-warning">Disabled</span>
                                                    }
                                                    </td>
                                                    <td>
                                                        @if (((WalletReport.Models.User)Session["CurrentUser"]).IsSuperUserOrAdmin || ((WalletReport.Models.User)Session["CurrentUser"]).isBank || ((WalletReport.Models.User)Session["CurrentUser"]).IsEtop || ((WalletReport.Models.User)Session["CurrentUser"]).IsDealer)
                                                        {
                                                            <a href="@Url.Content(String.Format("~/AssignTerminal/Create?Id={0}", d.TerminalID))">
                                                                <span class="label label-success">Edit</span>
                                                            </a>
                                                            if (d.IsActive)
                                                            {
                                                                <a href="@Url.Content(String.Format("~/AssignTerminal/Deactivate?Id={0}", d.TerminalID))">
                                                                    <span class="label label-warning">Disable</span>
                                                                </a>
                                                            }
                                                            else
                                                            {
                                                                <a href="@Url.Content(String.Format("~/AssignTerminal/Activate?Id={0}", d.TerminalID))">
                                                                    <span class="label label-warning">Enable</span>
                                                                </a>
                                                            }
                                                            if (((WalletReport.Models.User)Session["CurrentUser"]).IsSuperUserOrAdmin || ((WalletReport.Models.User)Session["CurrentUser"]).isBank || ((WalletReport.Models.User)Session["CurrentUser"]).IsEtop )
                                                            {
                                                                <a href="@Url.Content(String.Format("~/AssignTerminal/ManagePIN?Id={0}", d.TerminalID))">
                                                                    <span class="label label-success">Manage PIN</span>
                                                                </a>
                                                            }
                                                        }

                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                                @if ((bool)ViewBag.IsPagination)
                                {
                                     <div id="DataPager" class="row-fluid">
                                          <div id="DataPagerRight" class="pull-right">
                                              <div class="pagination">
                                                  @Html.Pager(Model.PageSize, Model.CurrentPageIndex, Model.ItemCount)
                                              </div>
                                              
                                         </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
}
@section scripts
{
    
@Scripts.Render("~/Scripts/library/footable/footable.js")
@Scripts.Render("~/Scripts/library/footable/data-generator.js")
@Scripts.Render("~/Scripts/library/bootstrapSwitch.js")
@Scripts.Render("~/Scripts/library/bootstrap-modal.js")
@Scripts.Render("~/Scripts/library/bootstrap-modalmanager.js")
@Scripts.Render("~/Scripts/library/editor/wysihtml5-0.3.0.js")
@Scripts.Render("~/Scripts/library/editor/bootstrap-wysihtml5.js")
@Scripts.Render("~/Scripts/forms_advanced.js")


    <script type="text/javascript">



        jQuery(document).ready(function () {

            jQuery('#DataPagerRight a').click(function () {

                var pageIndex = jQuery(this).attr("data-PageIndex");

                jQuery("#CurrentPageIndex").val(pageIndex);

                var form = jQuery("form#form1");
                form.attr("action", "@Url.Action("Index","AssignTerminal")");
                form.submit();

                return true;

            });

            jQuery("#PageSize").change(function () {
                var form = jQuery("form#form1");
                form.attr("action", "@Url.Action("Index","AssignTerminal")");
                try {
                    jQuery("#CurrentPageIndex").val("0");
                }
                catch (e) {
                }
                form.submit();

                return true;
            });
        });
        function Search() {
            jQuery("#CurrentPageIndex").val("0");
            var form = jQuery("form#form1");
            form.attr("action", "@Url.Action("Index","AssignTerminal")");
            form.submit();
            return true;
        }
    </script>
	
	
}