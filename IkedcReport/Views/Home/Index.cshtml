@model WalletReport.Models.DashBoardModel
@{
    ViewBag.Title = "Home Page";
}
<div id="content">
    <div class="inner_content">
        <div class="statistic clearfix">
            <div class="current_page pull-left">
                <span><i class="icon-laptop"></i>Dashboard</span> 
                
                @if (Model.Dealer == null && Model.AgentUser == null)
                {
                    <span class="hidden-480 quote">
                        WALLET PORTAL!
                    </span>
                }
                else
                {
                    if (Model.Dealer != null)
                    {
                        <span class="hidden-480 quote">
                            WALLET PORTAL! MY WALLET BAL IS:<span style="color:red">(@Model.Dealer.Balance.ToString("N2"))</span>
                        </span>
                    }
                    else
                    {
                        <span class="hidden-480 quote">
                            WALLET PORTAL! MY WALLET BAL IS:<span style="color:red">(@Model.AgentUser.Balance.ToString("N2"))</span>
                        </span>
                    }

                }
            </div>
           
        </div>
        <div class="report-widgets hidden-480 hidden-768">
            <div class="row-fluid">
                <div class="span3">
                    <div class="widget yellow clearfix">
                        <div class="content">
                            <div class="icon">
                                <span>@DateTime.Now.AddDays(-1).ToString("dd/MM/yyyy")</span>  Total(DR) [@Model.TwoDaysSummary.TotalDebit.ToString("#,##0")]
                            </div>
                            <div class="value">
                                <span>@DateTime.Now.AddDays(-1).ToString("dd/MM/yyyy")</span>  Total(CR) @Model.TwoDaysSummary.TotalCredit.ToString("N2")
                            </div>
                        </div>
                        <a href="#" class="more"><i class="icon-arrow-right"></i></a>
                    </div>
                </div>
                <div class="span3">
                    <div class="widget yellow clearfix">
                        <div class="content">
                            <div class="icon">
                                @*<i class="icon-globe"></i>*@
                                Yesterday Total(DR) [@Model.YesterdaySummary.TotalDebit.ToString("#,##0")]
                            </div>
                            <div class="value">
                                Yesterday Total(CR) @Model.YesterdaySummary.TotalCredit.ToString("N2")
                            </div>
                        </div>
                        <a href="#" class="more"><i class="icon-arrow-right"></i></a>
                    </div>
                </div>
                <div class="span3">
                    <div class="widget yellow clearfix">
                        <div class="content">
                            <div class="icon">
                                @*<i class="icon-bar-chart"></i>*@
                                Todays Total(DR)   [@Model.Today.TotalDebit.ToString("#,##0")]
                            </div>
                            <div class="value">
                                Todays Total(DR) @Model.Today.TotalCredit.ToString("N2")
                            </div>
                        </div>
                        <a href="#" class="more"><i class="icon-arrow-right"></i></a>
                    </div>
                </div>
                <div class="span3">
                    <div class="widget dark_green clearfix">
                        <div class="content">
                            <div class="icon">
                                @* <i class="icon-globe"></i>*@
                                This Week Debit  (@Model.WeeklySummary.TotalDebit.ToString("N2"))
                            </div>
                            <div class="value">
                                This Week Credit (@Model.WeeklySummary.TotalDebit.ToString("N2"))
                            </div>
                        </div>
                        <a href="#" class="more"><i class="icon-arrow-right"></i></a>
                    </div>
                </div>
            </div>

        </div>
        <div class="widgets_area">
            <div class="row-fluid">
                <div class="span12">
                    <div class="well grey">
                        <div class="well-header">
                            <h5>Transaction Last(15)</h5>
                        </div>

                        <div class="well-content">
                            <table class="table table-striped table-bordered table-hover datatable">
                                <thead>
                                   <tr>
                                        <th>SN</th>
                                         <th>Date</th>
                                        <th>Terminal</th>
                                        <th>Customer Ref</th>
                                        <th>Reference</th>
                                        <th>Description</th>
                                        <th>Transaction Amt</th>
                                        <th>TranType</th>
                                        <th>Dealer Name</th>
                                     </tr>
                                </thead>
                                <tbody>
                                    @if (Model.WalletTransaction != null && Model.WalletTransaction.Count() > 0)
                                    {
                                        int count = 0;
                                        foreach (WalletReport.Models.WalletTransaction tran in Model.WalletTransaction)
                                        {
                                            ++count;
                                             <tr>
                                                    <td><a href="@Url.Action("Detail", new { id=tran.TranID})">@count</a></td>
                                                    <td>@tran.TransactionDateBuild</td>
                                                    <td>@tran.TerminalID</td>
                                                    <td>@tran.CustomerRef</td>
                                                    <td>
                                                        <a href="@Url.Action("Detail", new { id=tran.TranID})">@tran.Reference</a>
                                                    </td>
                                                    <td>@tran.Description</td>
                                                    @if (tran.LastTransactionAmt > 0)
                                                    {
                                                        <td>@tran.LastTransactionAmt</td>
                                                    }
                                                    else
                                                    {
                                                        <td><span style="color:red">@tran.LastTransactionAmt</span></td>
                                                    }
                                                    <td>@tran.TransactionType</td>
                                                    <td>@tran.DealerName</td>
                                                </tr>
                                        }

                                    }
                                    else
                                    {
                                         <tr>
                                                <td>&nbsp;</td>
                                                <td>&nbsp;</td>
                                                <td>&nbsp;</td>
                                                <td>&nbsp;</td>
                                                <td>&nbsp;</td>
                                                <td>&nbsp;</td>
                                                <td>&nbsp;</td>
                                                <td>&nbsp;</td>
                                                <td>&nbsp;</td>
                                            </tr>
                                    }

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Le javascript
    ================================================== -->
<!-- Placed at the end of the document so the pages load faster -->
@section scripts
{

    <script>
        window.setTimeout(function () { document.location.reload(true); }, 60000);
        jQuery('#vmap').vectorMap({
            map: "world_en",
            backgroundColor: null,
            color: "#ffffff",
            hoverOpacity: .7,
            selectedColor: "#2d91ef",
            enableZoom: 0,
            showTooltip: 1,
            values: sample_data,
            scaleColors: ["#8cc3f6", "#5c86ac"],
            normalizeFunction: "polynomial",
            onRegionClick: function () {
                alert("This Region has " + (Math.floor(Math.random() * 10) + 1) + " users!"
                )
            }
        });

        jQuery(document).ready(function () {
            $('.footable').footable();
            $('.responsive_table_container').mCustomScrollbar({
                set_height: 400,
                advanced: {
                    updateOnContentResize: true,
                    updateOnBrowserResize: true
                }
            });

            $('.responsive_table_container_2').mCustomScrollbar({
                set_height: 520,
                advanced: {
                    updateOnContentResize: true,
                    updateOnBrowserResize: true
                }
            });

            $('.inner_sidebar').easytabs({
                animationSpeed: 300,
                collapsible: false,
                updateHash: false
            });
        });
    </script>
    @Scripts.Render("~/Scripts/calendar.js");
    @Scripts.Render("~/Scripts/forms.js");
    @Scripts.Render("~/Scripts/dashboard.js");
    }
